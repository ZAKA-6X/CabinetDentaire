%% Diagramme d'activités — Système de Gestion de Clinique Dentaire
%% Couvre : Inscription, Réservation de rendez-vous, Confirmation secrétaire,
%%          Enregistrement de visite dentiste, Ordonnance, Facturation, Paiement

flowchart TD

    %% ─── INSCRIPTION PATIENT ────────────────────────────────────────
    A([Visiteur ouvre le site]) --> B[Cliquer sur S'inscrire]
    B --> C[Remplir le formulaire d'inscription\nnom · téléphone · adresse · DDN · email · mot de passe]
    C --> D{Formulaire valide?}
    D -- Non --> C
    D -- Oui --> E[Créer le compte\nStatut = ACTIF]
    E --> F[Redirection vers la connexion]

    %% ─── CONNEXION ───────────────────────────────────────────────────
    F --> G[Saisir email + mot de passe]
    G --> H{Identifiants corrects?}
    H -- Non --> G
    H -- Oui, Patient --> I[Tableau de bord Patient]
    H -- Oui, Secrétaire --> S1[Tableau de bord Secrétaire]
    H -- Oui, Dentiste --> D1[Tableau de bord Dentiste]

    %% ═══════════════════════════════════════════════════════════════════
    %% FLUX PATIENT
    %% ═══════════════════════════════════════════════════════════════════
    I --> J[Cliquer sur Réserver un rendez-vous]
    J --> K[Sélectionner une date dans le calendrier]
    K --> L[Système affiche les créneaux disponibles]
    L --> M[Patient sélectionne un créneau horaire]
    M --> N[Optionnel : ajouter des notes / raison de visite]
    N --> O[Soumettre la réservation]
    O --> P[Statut rendez-vous = EN_ATTENTE]
    P --> Q[Message de confirmation affiché au patient]

    %% Annulation de rendez-vous en attente
    I --> I1[Voir mes rendez-vous]
    I1 --> I2{Statut = EN_ATTENTE?}
    I2 -- Oui --> I3[Annuler le rendez-vous\nStatut = ANNULÉ]
    I2 -- Non --> I4[Consultation uniquement — annulation impossible]

    %% Vues patient
    I --> V1[Voir l'historique des visites]
    I --> V2[Voir les ordonnances\nTélécharger en PDF]
    I --> V3[Voir les factures\nTélécharger en PDF]

    %% ═══════════════════════════════════════════════════════════════════
    %% FLUX SECRÉTAIRE — CONFIRMATION DES RENDEZ-VOUS
    %% ═══════════════════════════════════════════════════════════════════
    S1 --> S2[Voir les rendez-vous en attente]
    S2 --> S3[Sélectionner un rendez-vous à examiner]
    S3 --> S4[Vérifier les détails du patient et le créneau]
    S4 --> S5{Conflit de créneau?}
    S5 -- Oui --> S6[Rejeter le rendez-vous\nStatut = ANNULÉ\nEnvoyer email d'annulation]
    S5 -- Non --> S7{Confirmer ou Rejeter?}
    S7 -- Confirmer --> S8[Statut = CONFIRMÉ\nEnvoyer email de confirmation au patient]
    S7 -- Rejeter --> S6

    %% Secrétaire — confirmation de paiement
    S1 --> S9[Voir les factures en attente]
    S9 --> S10[Patient paie en espèces à la clinique]
    S10 --> S11[Secrétaire marque la facture PAYÉE]
    S11 --> S12[Générer le reçu\nEnvoyer email de confirmation au patient]

    %% Secrétaire — gestion des médicaments
    S1 --> S13[Gérer la liste des médicaments\nAjouter / Modifier des médicaments]

    %% Secrétaire — gestion des tarifs des opérations
    S1 --> S14[Voir les opérations dentaires]
    S14 --> S15[Modifier le tarif d'une opération\nex: Détartrage · Remplissage · etc.]
    S15 --> S16[Enregistrer le nouveau tarif]

    %% ═══════════════════════════════════════════════════════════════════
    %% FLUX DENTISTE — ENREGISTREMENT DE VISITE
    %% ═══════════════════════════════════════════════════════════════════
    D1 --> D2[Voir les rendez-vous confirmés du jour]
    D2 --> D3[Patient arrive à la clinique]
    D3 --> D4[Sélectionner le rendez-vous confirmé]
    D4 --> D5[Saisir les détails de la visite :\nDiagnostic · Traitement · Notes]
    D5 --> D6[Ajouter les opérations dentaires\nDétartrage · Remplissage · etc. avec coûts]
    D6 --> D7[Cliquer sur Marquer comme complété]
    D7 --> D8[Système crée l'enregistrement VISITE\nStatut rendez-vous = COMPLÉTÉ]
    D8 --> D9[Système génère automatiquement la FACTURE\nTotal = Frais de base + Coût des opérations\nStatut facture = EN_ATTENTE]

    %% Ordonnance — branche optionnelle
    D9 --> D10{Émettre une ordonnance?}
    D10 -- Oui --> D11[Sélectionner les médicaments dans la liste]
    D11 --> D12[Définir la fréquence + durée par médicament]
    D12 --> D13[Ajouter des instructions générales optionnel]
    D13 --> D14[Enregistrer l'ordonnance\nStatut = ACTIF]
    D14 --> D15[Visite entièrement enregistrée]
    D10 -- Non --> D15

    D15 --> D16[Patient peut consulter :\nDétails visite · Facture · Ordonnance PDF]

    %% ─── STYLES ──────────────────────────────────────────────────────
    classDef patient    fill:#3b82f6,color:#fff,stroke:#1d4ed8
    classDef secretaire fill:#10b981,color:#fff,stroke:#047857
    classDef dentiste   fill:#f59e0b,color:#fff,stroke:#b45309
    classDef systeme    fill:#8b5cf6,color:#fff,stroke:#6d28d9
    classDef decision   fill:#f3f4f6,color:#111,stroke:#6b7280

    class I,I1,I2,I3,I4,J,K,M,N,O,V1,V2,V3 patient
    class S1,S2,S3,S4,S5,S6,S7,S8,S9,S10,S11,S12,S13,S14,S15,S16 secretaire
    class D1,D2,D3,D4,D5,D6,D7,D11,D12,D13 dentiste
    class P,D8,D9,D14,D15,D16,E systeme
    class D,H,I2,S5,S7,D10 decision
